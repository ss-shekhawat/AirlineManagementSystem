# Java compiled files
*.class
*.jar
*.war
*.ear
target/
build/
out/
bin/

# IDE files
.idea/
*.iml
.vscode/
.settings/
.classpath
.project
*.swp
*.swo

# Frontend dependencies
frontend/node_modules/
